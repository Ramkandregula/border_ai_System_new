# Environment Configuration
# Database
DATABASE_URL=postgresql://border_user:border_password@db:5432/border_ai_db
DB_HOST=db
DB_PORT=5432
DB_USER=border_user
DB_PASSWORD=border_password
DB_NAME=border_ai_db

# API Configuration
API_SECRET_KEY=your-super-secret-key-change-this-in-production-12345678
API_ALGORITHM=HS256
API_TOKEN_EXPIRE_MINUTES=30
API_REFRESH_TOKEN_EXPIRE_DAYS=7
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ML Models Configuration
MODEL_PERSON_DETECTION=yolov8m.pt
MODEL_PERSON_DETECTION_CONFIDENCE=0.5
MODEL_OCR_ENGINE=tesseract
MODEL_CACHE_DIR=/app/models
MAX_DETECTION_PERSONS=50
DETECTION_FPS=30

# Threat Analysis
THREAT_MODEL_PATH=/app/models/threat_analysis.pkl
THREAT_ANALYSIS_ENABLED=true
THREAT_THRESHOLD=0.6

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-change-this-12345
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/border_ai/app.log

# Frontend
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000/ws
REACT_APP_API_TIMEOUT=30000

# Security
SECURITY_ENABLED=true
ENABLE_HTTPS=false
CERT_PATH=/app/certs/cert.pem
KEY_PATH=/app/certs/key.pem

# File Upload
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIR=/app/uploads
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.pdf,.doc,.docx

# Queue Configuration
MAX_QUEUE_SIZE=100
QUEUE_TIMEOUT_MINUTES=30
QUEUE_PRIORITY_LEVELS=5

# Audit & Compliance
AUDIT_LOGGING_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90
COMPLIANCE_MODE=true

# Email Notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_EMAIL=admin@border-ai.com

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
ENABLE_METRICS=true

# Feature Flags
ENABLE_DETECTION=true
ENABLE_OCR=true
ENABLE_THREAT_ANALYSIS=true
ENABLE_QUEUE_MANAGEMENT=true